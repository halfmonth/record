          <mxGeometry height="60" width="160" x="500" y="509" as="geometry" />
        </mxCell>
        <mxCell id="unrEiKPNrD50Kh5umRMT-22" edge="1" parent="1" source="unrEiKPNrD50Kh5umRMT-23" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;entryX=0.25;entryY=1;entryDx=0;entryDy=0;startArrow=classic;startFill=1;" target="unrEiKPNrD50Kh5umRMT-5">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="unrEiKPNrD50Kh5umRMT-23" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;" value="&lt;div style=&quot;text-align: start;&quot;&gt;&lt;font face=&quot;Noto Sans SC, sans-serif&quot; style=&quot;font-size: 18px;&quot;&gt;&lt;span style=&quot;background-color: rgb(255, 255, 255);&quot;&gt;人工审核&lt;/span&gt;&lt;/font&gt;&lt;/div&gt;" vertex="1">
          <mxGeometry height="60" width="120" x="815" y="274" as="geometry" />
        </mxCell>
        <mxCell id="unrEiKPNrD50Kh5umRMT-24" parent="1" style="rounded=1;whiteSpace=wrap;html=1;" value="&lt;font style=&quot;font-size: 18px;&quot;&gt;报告生成&lt;/font&gt;" vertex="1">
          <mxGeometry height="60" width="120" x="640" y="504" as="geometry" />
        </mxCell>
        <mxCell id="unrEiKPNrD50Kh5umRMT-25" edge="1" parent="1" source="unrEiKPNrD50Kh5umRMT-8" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;exitX=0.25;exitY=1;exitDx=0;exitDy=0;entryX=0.35;entryY=-0.05;entryDx=0;entryDy=0;entryPerimeter=0;" target="unrEiKPNrD50Kh5umRMT-24">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="unrEiKPNrD50Kh5umRMT-26" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;rounded=0;fontStyle=1;fontSize=16;" value="解决的关键问题：&lt;div&gt;1：&lt;span style=&quot;background-color: transparent;&quot;&gt;mock 层搭建成本高 — 嵌入式 SDK 依赖多（VolcEngine RTC、 MPI、SecureC）&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;background-color: transparent;&quot;&gt;2：手工 mock 耗时且易出错；方案自动分析依赖并生成完整 mock 桩&lt;/span&gt;&lt;div&gt;3：手工用例覆盖不系统 — 人工容易遗漏边界、错误路径；方案按函数分类（纯逻辑/初始化/SDK依赖）系统生成&lt;/div&gt;&lt;div&gt;4：结果不可见 — 生成带缺陷定位的可视化 HTML 报告，直接呈现风险点&lt;/div&gt;&lt;/div&gt;" vertex="1">
          <mxGeometry height="200" width="940" x="40" y="539" as="geometry" />
        </mxCell>
        <mxCell id="unrEiKPNrD50Kh5umRMT-27" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;rounded=0;fontSize=15;" value="从&quot;帮我写UT&quot;到首次编译通过：约 30-60 分钟/文件" vertex="1">
          <mxGeometry height="50" width="340" x="800" y="509" as="geometry" />
        </mxCell>
        <mxCell id="unrEiKPNrD50Kh5umRMT-28" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;rounded=0;fontSize=15;" value="&lt;span style=&quot;background-color: transparent;&quot;&gt;理解需求 + 分析边界/错误路径/枚举遍历：~2-4小时/文件&lt;/span&gt;&lt;div&gt;手写 mock 桩层 + 测试代码：~4-8小时/文件&lt;/div&gt;&lt;div&gt;调试编译/维护：~2-4小时&lt;/div&gt;" vertex="1">
          <mxGeometry height="30" width="430" x="45" y="509" as="geometry" />
        </mxCell>
        <mxCell id="unrEiKPNrD50Kh5umRMT-29" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;rounded=0;fontSize=18;" value="&lt;font style=&quot;font-size: 36px;&quot;&gt;&lt;b&gt;AI开发UT用例&lt;/b&gt;&lt;/font&gt;" vertex="1">
          <mxGeometry height="30" width="265" x="470" y="30" as="geometry" />
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
